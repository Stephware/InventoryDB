@{
    ViewData["Title"] = "Register";
}

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<style>
    /* Custom Color Palette & Styling */
    .brand-color {
        color: #4F46E5;
    }

    .bg-brand {
        background-color: #4F46E5;
        border-color: #4F46E5;
    }

        .bg-brand:hover {
            background-color: #4338ca;
            border-color: #4338ca;
        }

    .page-wrapper {
        background: linear-gradient(135deg, #f3f4f6 0%, #e5e7eb 100%);
    }

    .card-custom {
        border-radius: 1.25rem;
        border: none;
    }

    .form-control:focus {
        border-color: #4F46E5;
        box-shadow: 0 0 0 0.25rem rgba(79, 70, 229, 0.25);
    }
</style>

<div class="d-flex justify-content-center align-items-center vh-100 page-wrapper">
    <div class="card shadow-lg p-5 card-custom" style="width:420px;">

        <div class="text-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="56" height="56" fill="currentColor" class="bi bi-person-plus-fill brand-color mb-3" viewBox="0 0 16 16">
                <path d="M1 14s-1 0-1-1 1-4 6-4 6 3 6 4-1 1-1 1H1zm5-6a3 3 0 1 0 0-6 3 3 0 0 0 0 6z" />
                <path fill-rule="evenodd" d="M13.5 5a.5.5 0 0 1 .5.5V7h1.5a.5.5 0 0 1 0 1H14v1.5a.5.5 0 0 1-1 0V8h-1.5a.5.5 0 0 1 0-1H13V5.5a.5.5 0 0 1 .5-.5z" />
            </svg>
            <h3 class="fw-bold text-dark">Create Account</h3>
            <p class="text-muted small">Join the inventory management system today.</p>
        </div>

        <form method="post">
            <div class="mb-3">
                <label class="form-label fw-semibold text-secondary">Choose Username</label>
                <input type="text" name="username" class="form-control form-control-lg bg-light" placeholder="Username" required />
            </div>

            <div class="mb-4">
                <label class="form-label fw-semibold text-secondary">Create Password</label>
                <input type="password" name="password" class="form-control form-control-lg bg-light" placeholder="Password" required />
            </div>

            <button type="submit" class="btn bg-brand text-white w-100 py-2 fw-bold fs-5">Register</button>
        </form>

        <div class="text-center mt-4">
            <small class="text-muted">Already have an account?</small><br />
            <a href="/Account/Login" class="text-decoration-none brand-color fw-semibold">Login here</a>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        @if (ViewBag.Error != null)
        {
                <text>
                Swal.fire({
                    icon: 'error',
                    title: 'Registration Failed',
                    text: '@ViewBag.Error',
                    confirmButtonColor: '#4F46E5'
                });
                </text>
        }
    });
</script>